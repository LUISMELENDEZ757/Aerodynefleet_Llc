{
  "name": "MELItem",
  "type": "object",
  "description": "Minimum Equipment List deferred item per aircraft.",
  "properties": {
    "aircraft_tail": {
      "type": "string"
    },
    "aircraft_type": {
      "type": "string"
    },
    "ata_chapter": {
      "type": "string"
    },
    "item_number": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "A",
        "B",
        "C",
        "D"
      ],
      "description": "MEL category: A=ASAP, B=3days, C=10days, D=120days"
    },
    "deferred_date": {
      "type": "string",
      "format": "date"
    },
    "expiry_date": {
      "type": "string",
      "format": "date"
    },
    "placard_required": {
      "type": "boolean",
      "default": false
    },
    "ops_procedure": {
      "type": "string"
    },
    "mx_procedure": {
      "type": "string"
    },
    "flight_restrictions": {
      "type": "string"
    },
    "etops_critical": {
      "type": "boolean",
      "default": false
    },
    "etops_impact": {
      "type": "string",
      "enum": [
        "OK",
        "NO_ETOPS",
        "ETOPS_WITH_LIMITS"
      ],
      "default": "OK"
    },
    "etops_limit_rating": {
      "type": "number"
    },
    "etops_notes": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "expiring_soon",
        "expired",
        "cleared"
      ],
      "default": "open"
    },
    "cleared_date": {
      "type": "string",
      "format": "date"
    },
    "cleared_by": {
      "type": "string"
    },
    "logpage_number": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "aircraft_tail",
    "description",
    "category",
    "deferred_date"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "technician"
          }
        }
      ]
    },
    "read": {},
    "update": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "mcc_supervisor"
          }
        },
        {
          "user_condition": {
            "role": "engineer"
          }
        },
        {
          "user_condition": {
            "role": "technician"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}